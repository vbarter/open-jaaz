# Google OAuth
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
LOCALHOST_REDIRECT_URI=http://127.0.0.1:8000
BASE_URL=http://127.0.0.1:8000

# 腾讯云 COS
COS_SECRET_ID=YOUR_COS_SECRET_ID
COS_SECRET_KEY=YOUR_COS_SECRET_KEY
COS_REGION=accelerate

# Payment Configuration - Choose provider: creem or stripe
PAYMENT_PROVIDER=stripe

# Creem Payment
CREEM_API_URL=https://test-api.creem.io
CREEM_API_KEY=creem_test_YOUR_KEY

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
STRIPE_SUCCESS_URL=http://localhost:8000/payments
STRIPE_CANCEL_URL=http://localhost:3000/pricing
PAYMENT_DEV_MODE=false  # Set to true to skip actual payment processing (dev only)

# Supabase
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_KEY=YOUR_SUPABASE_KEY
SUPABASE_DB=magicart
SUPABASE_MAX_RETRIES=3
SUPABASE_RETRY_DELAY=1

# TuZi API
TUZI_API_KEY=YOUR_TUZI_API_KEY